{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@ryan/core": ["packages/core/src/index.ts"],
      "@ryan/ui": ["packages/ui/src/index.ts"],
      "@ryan/db": ["packages/db/src/index.ts"]
    }
  }
}
