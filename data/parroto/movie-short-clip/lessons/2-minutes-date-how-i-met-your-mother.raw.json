      },
      "ipa": "ˈjɛə, ˈaɪ ˈɑlˌmoʊst ˈwɑkt ˈaʊt laɪk ˈfaɪv ˈtaɪmz.",
      "start_ms": 106660,
      "end_ms": 108500
    },
    {
      "_id": "69199f69b41f5ecfe3202efc",
      "text": "How we doing?",
      "translations": {
        "vi": "Chúng ta thế nào rồi?",
        "th": "เราเป็นยังไงบ้าง?",
        "id": "Bagaimana kita?",
        "ar": "كيف حالنا؟?"
      },
      "ipa": "ˈhaʊ wi ˈduːɪŋ?",
      "start_ms": 108940,
      "end_ms": 109340
    },
    {
      "_id": "69199f69b41f5ecfe3202efe",
      "text": "On time?",
      "translations": {
        "vi": "Đúng giờ không?",
        "th": "ตรงเวลาไหม?",
        "id": "Tepat waktu?",
        "ar": "في الوقت المحدد؟?"
      },
      "ipa": "ɑn ˈtaɪm?",
      "start_ms": 109340,
      "end_ms": 109700
    },
    {
      "_id": "69199f69b41f5ecfe3202f00",
      "text": "Taxi.",
      "translations": {
        "vi": "Taxi.",
        "th": "แท็กซี่.",
        "id": "Taksi.",
        "ar": "تاكسي."
      },
      "ipa": "ˈtæksi.",
      "start_ms": 109700,
      "end_ms": 110060
    },
    {
      "_id": "69199f69b41f5ecfe3202f02",
      "text": "We got a little time.",
      "translations": {
        "vi": "Chúng ta có một chút thời gian.",
        "th": "เรามีเวลานิดหน่อย.",
        "id": "Kita punya sedikit waktu.",
        "ar": "لدينا القليل من الوقت."
      },
      "ipa": "wi ˌɡɑt ə ˌlɪɾəl ˈtaɪm.",
      "start_ms": 110060,
      "end_ms": 111860
    },
    {
      "_id": "69199f69b41f5ecfe3202f04",
      "text": "OK.",
      "translations": {
        "vi": "OK.",
        "th": "โอเค.",
        "id": "Oke.",
        "ar": "حسناً."
      },
      "ipa": "ˌoʊˈkeɪ.",
      "start_ms": 112140,
      "end_ms": 112420
    },
    {
      "_id": "69199f69b41f5ecfe3202f06",
      "text": "You want to walk it?",
      "translations": {
        "vi": "Anh muốn đi bộ không?",
        "th": "คุณอยากเดินไปไหม?",
        "id": "Kau mau jalan kaki?",
        "ar": "هل تريد أن نمشي؟?"
      },
      "ipa": "jə ˌwɑnə ˈwɔk ɪt?",
      "start_ms": 112420,
      "end_ms": 113300
    },
    {
      "_id": "69199f69b41f5ecfe3202f08",
      "text": "Why not?",
      "translations": {
        "vi": "Tại sao không?",
        "th": "ทำไมจะไม่ล่ะ?",
        "id": "Kenapa tidak?",
        "ar": "لم لا؟?"
      },
      "ipa": "ˈwaɪ ˈnɑt?",
      "start_ms": 114020,
      "end_ms": 114580
    },
    {
      "_id": "69199f69b41f5ecfe3202f0a",
      "text": "Hello.",
      "translations": {
        "vi": "Xin chào.",
        "th": "สวัสดี.",
        "id": "Halo.",
        "ar": "مرحباً."
      },
      "ipa": "həˈloʊ.",
      "start_ms": 115100,
      "end_ms": 115260
    },
    {
      "_id": "69199f69b41f5ecfe3202f0c",
      "text": "Goodbye.",
      "translations": {
        "vi": "Tạm biệt.",
        "th": "ลาก่อน.",
        "id": "Selamat tinggal.",
        "ar": "وداعاً."
      },
      "ipa": "ˌɡʊdˈbaɪ.",
      "start_ms": 116420,
      "end_ms": 116740
    },
    {
      "_id": "69199f69b41f5ecfe3202f0e",
      "text": "So what grade's your daughter?",
      "translations": {
        "vi": "Vậy con gái anh học lớp mấy?",
        "th": "แล้วลูกสาวคุณอยู่ชั้นอะไร?",
        "id": "Jadi putri Anda kelas berapa?",
        "ar": "إذاً في أي صف ابنتك؟?"
      },
      "ipa": "soʊ wʌt ˈɡreɪdz jər ˈdɔɾər?",
      "start_ms": 118480,
      "end_ms": 119440
    },
    {
      "_id": "69199f69b41f5ecfe3202f10",
      "text": "In 3rd grade.",
      "translations": {
        "vi": "Lớp 3.",
        "th": "อยู่ชั้นประถมปีที่ 3.",
        "id": "Kelas 3.",
        "ar": "في الصف الثالث."
      },
      "ipa": "ɪn ˌθɝd ˈɡreɪd.",
      "start_ms": 119440,
      "end_ms": 120480
    },
    {
      "_id": "69199f69b41f5ecfe3202f12",
      "text": "It's a good year.",
      "translations": {
        "vi": "Đó là một năm tốt.",
        "th": "เป็นปีที่ดี.",
        "id": "Ini tahun yang baik.",
        "ar": "إنها سنة جيدة."
      },
      "ipa": "ɪts ə ˌɡʊd ˈjɪr.",
      "start_ms": 121000,
      "end_ms": 121520
    },
    {
      "_id": "69199f69b41f5ecfe3202f14",
      "text": "Yeah, she's wonderful.",
      "translations": {
        "vi": "Vâng, con bé tuyệt vời.",
        "th": "ใช่ เธอวิเศษมาก.",
        "id": "Ya, dia luar biasa.",
        "ar": "أجل، إنها رائعة."
      },
      "ipa": "jɛə, ʃiːz ˈwʌndɚfəl.",
      "start_ms": 121840,
      "end_ms": 122920
    },
    {
      "_id": "69199f69b41f5ecfe3202f16",
      "text": "I just wish that I could get her to quit smoking.",
      "translations": {
        "vi": "Tôi chỉ ước tôi có thể khiến con bé bỏ thuốc lá.",
        "th": "ฉันแค่หวังว่าฉันจะทำให้เธอเลิกบุหรี่ได้.",
        "id": "Aku hanya berharap aku bisa membuatnya berhenti merokok.",
        "ar": "أتمنى لو أستطيع أن أجعلها تتوقف عن التدخين."
      },
      "ipa": "ˈaɪ ˈdʒʌst ˈwɪʃ ðət ˈaɪ kəd ˈɡɛt ər tə ˈkwɪt ˈsmoʊkɪŋ.",
      "start_ms": 123200,
      "end_ms": 125160
    },
    {
      "_id": "69199f69b41f5ecfe3202f18",
      "text": "You know what?",
      "translations": {
        "vi": "Anh biết không?",
        "th": "คุณรู้ไหม?",
        "id": "Kau tahu apa?",
        "ar": "أتعلم ماذا؟?"
      },
      "ipa": "jə ˌnoʊ ˈwʌt?",
      "start_ms": 125160,
      "end_ms": 125920
    },
    {
      "_id": "69199f69b41f5ecfe3202f1a",
      "text": "I'm kidding.",
      "translations": {
        "vi": "Tôi đùa đấy.",
        "th": "ฉันล้อเล่น.",
        "id": "Aku bercanda.",
        "ar": "أنا أمزح."
      },
      "ipa": "aɪm ˈkɪdɪŋ.",
      "start_ms": 126440,
      "end_ms": 126840
    },
    {
      "_id": "69199f69b41f5ecfe3202f1c",
      "text": "Oh, little coffee and dessert.",
      "translations": {
        "vi": "Ồ, một chút cà phê và món tráng miệng.",
        "th": "โอ้ กาแฟกับของหวานนิดหน่อย.",
        "id": "Oh, sedikit kopi dan hidangan penutup.",
        "ar": "أوه، قهوة صغيرة وحلوى."
      },
      "ipa": "oʊ, ˈlɪɾəl ˈkɑfi ən dɪˈzɜrt.",
      "start_ms": 126840,
      "end_ms": 129000
    },
    {
      "_id": "69199f69b41f5ecfe3202f20",
      "text": "You know, this neighborhood just keeps on changing.",
      "translations": {
        "vi": "Anh biết không, khu phố này cứ thay đổi mãi.",
        "th": "คุณรู้ไหม ย่านนี้มันเปลี่ยนไปเรื่อยๆ เลย.",
        "id": "Kau tahu, lingkungan ini terus berubah.",
        "ar": "تعلم، هذا الحي يستمر في التغير."
      },
      "ipa": "ju ˈnoʊ, ðɪs ˈneɪbərˌhʊd dʒʌst ˈkiːps ɑn ˈtʃeɪndʒɪŋ.",
      "start_ms": 130520,
      "end_ms": 132320
    },
    {
      "_id": "69199f69b41f5ecfe3202f23",
      "text": "This used to be a cute little Italian restaurant.",
      "translations": {
        "vi": "Đây từng là một nhà hàng Ý nhỏ xinh.",
        "th": "ที่นี่เคยเป็นร้านอาหารอิตาเลียนเล็กๆ น่ารัก.",
        "id": "Ini dulunya restoran Italia kecil yang lucu.",
        "ar": "كان هذا مطعماً إيطالياً صغيراً ولطيفاً."
      },
      "ipa": "ðɪs juːstə bi ə ˌkjuːt ˌlɪɾəl ɪˈtæljən ˈrɛstərɑːnt.",
      "start_ms": 132320,
      "end_ms": 133920
    },
    {
      "_id": "69199f69b41f5ecfe3202f29",
      "text": "I know.",
      "translations": {
        "vi": "Tôi biết.",
        "th": "ฉันรู้.",
        "id": "Aku tahu.",
        "ar": "أعرف."
      },
      "ipa": "ˈaɪ ˈnoʊ.",
      "start_ms": 134040,
      "end_ms": 134360
    },
    {
      "_id": "69199f69b41f5ecfe3202f2d",
      "text": "New York.",
      "translations": {
        "vi": "New York.",
        "th": "นิวยอร์ก.",
        "id": "New York.",
        "ar": "نيويورك."
      },
      "ipa": "ˌnuː ˈjɔːrk.",
      "start_ms": 134440,
      "end_ms": 134960
    },
    {
      "_id": "69199f69b41f5ecfe3202f31",
      "text": "It's a living Organism.",
      "translations": {
        "vi": "Nó là một Sinh vật sống.",
        "th": "มันคือสิ่งมีชีวิต.",
        "id": "Itu Organisme hidup.",
        "ar": "إنه كائن حي."
      },
      "ipa": "ɪts ə ˈlɪvɪŋ ˈɔrɡəˌnɪzəm.",
      "start_ms": 135280,
      "end_ms": 136200
    },
    {
      "_id": "69199f69b41f5ecfe3202f36",
      "text": "An ever changing tapestry.",
      "translations": {
        "vi": "Một tấm thảm không ngừng thay đổi.",
        "th": "ผืนผ้าที่เปลี่ยนแปลงอยู่เสมอ.",
        "id": "Sebuah permadani yang selalu berubah.",
        "ar": "نسيج يتغير باستمرار."
      },
      "ipa": "ən ˈɛvər ˈtʃeɪndʒɪŋ ˈtæpɪstri.",
      "start_ms": 136200,
      "end_ms": 137440
    },
    {
      "_id": "69199f69b41f5ecfe3202f39",
      "text": "Oh, look at the time.",
      "translations": {
        "vi": "Ồ, nhìn đồng hồ kìa.",
        "th": "โอ้ ดูเวลาสิ.",
        "id": "Oh, lihat jam.",
        "ar": "أوه، انظر إلى الوقت."
      },
      "ipa": "ˈoʊ, ˈlʊk ət ðə ˈtaɪm.",
      "start_ms": 137520,
      "end_ms": 138640
    },
    {
      "_id": "69199f69b41f5ecfe3202f3b",
      "text": "Let's go.",
      "translations": {
        "vi": "Đi thôi.",
        "th": "ไปกันเถอะ.",
        "id": "Ayo pergi.",
        "ar": "هيا بنا."
      },
      "ipa": "ˈlɛts ˈɡoʊ.",
      "start_ms": 139240,
      "end_ms": 139560
    },
    {
      "_id": "69199f69b41f5ecfe3202f3d",
      "text": "So she's amazing.",
      "translations": {
        "vi": "Vậy là cô ấy thật tuyệt vời.",
        "th": "งั้นเธอก็สุดยอดเลย.",
        "id": "Jadi dia luar biasa.",
        "ar": "إذاً هي مذهلة."
      },
      "ipa": "soʊ ʃiːz əˈmeɪzɪŋ.",
      "start_ms": 140680,
      "end_ms": 141520
    },
    {
      "_id": "69199f69b41f5ecfe3202f3f",
      "text": "Flowers.",
      "translations": {
        "vi": "Hoa.",
        "th": "ดอกไม้.",
        "id": "Bunga.",
        "ar": "زهور."
      },
      "ipa": "ˈflaʊ.ɚz.",
      "start_ms": 143240,
      "end_ms": 143680
    },
    {
      "_id": "69199f69b41f5ecfe3202f41",
      "text": "I'm allergic.",
      "translations": {
        "vi": "Tôi bị dị ứng.",
        "th": "ฉันแพ้.",
        "id": "Aku alergi.",
        "ar": "أنا لدي حساسية."
      },
      "ipa": "aɪm əˈlɜːrdʒɪk.",
      "start_ms": 144240,
      "end_ms": 144720
    },
    {
      "_id": "69199f69b41f5ecfe3202f43",
      "text": "OK, see, we're getting to know each other.",
      "translations": {
        "vi": "OK, thấy chưa, chúng ta đang tìm hiểu nhau đấy.",
        "th": "โอเค เห็นไหม เรากำลังทำความรู้จักกัน.",
        "id": "Oke, lihat, kita mulai saling mengenal.",
        "ar": "حسناً، انظر، نحن نتعرف على بعضنا البعض."
      },
      "ipa": "ˌoʊˈkeɪ, ˈsiː, wɪər ˈɡɛɾɪŋ tə ˈnoʊ ˌiːtʃ ˈʌðər.",
      "start_ms": 145520,
      "end_ms": 147920
    },
    {
      "_id": "69199f69b41f5ecfe3202f48",
      "text": "Stella, I had a lovely doggy back.",
      "translations": {
        "vi": "Stella, tôi đã có một cái lưng chó con đáng yêu.",
        "th": "สเตลล่า ฉันมีหมาน้อยน่ารักกลับมา.",
        "id": "Stella, aku punya punggung anjing yang manis.",
        "ar": "ستيلا، كان لدي ظهر كلب جميل."
      },
      "ipa": "ˈstɛlə, ˈaɪ ˈhæd ə ˈlʌvli ˈdɔɡi ˈbæk.",
      "start_ms": 148600,
      "end_ms": 151720
    },
    {
      "_id": "69199f69b41f5ecfe3202f4b",
      "text": "Stella, I had a lovely time.",
      "translations": {
        "vi": "Stella, tôi đã có một khoảng thời gian tuyệt vời.",
        "th": "สเตลล่า ฉันมีช่วงเวลาที่น่ารัก.",
        "id": "Stella, aku bersenang-senang.",
        "ar": "ستيلا، قضيت وقتاً رائعاً."
      },
      "ipa": "ˈstɛlə, aɪ ˈhæɾə ˈlʌvli ˈtaɪm.",
      "start_ms": 153160,
      "end_ms": 154800
    },
    {
      "_id": "69199f69b41f5ecfe3202f4d",
      "text": "Me too, Ted and date.",
      "translations": {
        "vi": "Tôi cũng vậy, Ted và buổi hẹn hò.",
        "th": "ฉันก็เหมือนกัน เท็ดกับเดท.",
        "id": "Aku juga, Ted dan kencan.",
        "ar": "أنا أيضاً، تيد والموعد."
      },
      "ipa": "ˈmiː ˈtuː, ˈtɛd ˌænd ˈdeɪt.",
      "start_ms": 154800,
      "end_ms": 158120
    },
