      "ipa": "dʒˈʌst ɪn ˈtaɪm.",
      "start_ms": 91240,
      "end_ms": 91880
    },
    {
      "_id": "69199f69b41f5ecfe3202eec",
      "text": "It hasn't started yet.",
      "translations": {
