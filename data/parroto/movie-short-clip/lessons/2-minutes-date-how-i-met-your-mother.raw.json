        "th": "แล้วเราคิดอะไรอยู่?",
        "id": "Jadi apa yang kita pikirkan?",
        "ar": "إذاً ما الذي نفكر فيه؟?"
      },
      "ipa": "ˌsoʊ ˈwʌɾ ər wi ˈθɪŋkɪŋ?",
      "start_ms": 93160,
      "end_ms": 94280
    },
    {
      "_id": "69199f69b41f5ecfe3202ef0",
      "text": "Longos.",
      "translations": {
        "vi": "Longos.",
        "th": "ลองโกส.",
        "id": "Longos.",
        "ar": "لونغوس."
      },
      "ipa": "ˈlɔŋɡoʊs.",
      "start_ms": 94280,
      "end_ms": 94640
    },
    {
      "_id": "69199f69b41f5ecfe3202ef2",
      "text": "Hands of bait.",
      "translations": {
        "vi": "Tay mồi.",
        "th": "มือเหยื่อ.",
        "id": "Tangan umpan.",
        "ar": "أيادي الطعم."
      },
      "ipa": "ˈhændz əv ˈbeɪt.",
      "start_ms": 94640,
      "end_ms": 95480
    },
    {
      "_id": "69199f69b41f5ecfe3202ef4",
      "text": "The whole thing.",
      "translations": {
        "vi": "Toàn bộ.",
        "th": "ทั้งหมดเลย.",
        "id": "Semuanya.",
        "ar": "كل شيء."
      },
      "ipa": "ðə ˈhoʊl ˈθɪŋ.",
      "start_ms": 95760,
      "end_ms": 96280
    },
    {
      "_id": "69199f69b41f5ecfe3202ef6",
      "text": "Only the important parts.",
      "translations": {
        "vi": "Chỉ những phần quan trọng.",
        "th": "แค่ส่วนสำคัญเท่านั้น.",
        "id": "Hanya bagian-bagian penting.",
        "ar": "الأجزاء المهمة فقط."
      },
      "ipa": "ˈoʊnli ðə ɪmˈpɔːr.t̬ənt pɑːrts.",
      "start_ms": 96280,
      "end_ms": 97360
    },
    {
      "_id": "69199f69b41f5ecfe3202ef8",
      "text": "Worst movie ever.",
      "translations": {
        "vi": "Bộ phim tệ nhất từ trước đến nay.",
        "th": "หนังที่แย่ที่สุดเท่าที่เคยมีมา.",
        "id": "Film terburuk yang pernah ada.",
        "ar": "أسوأ فيلم على الإطلاق."
      },
      "ipa": "[ˈwɝst ˈmuːvi ˈɛvər.].",
      "start_ms": 104380,
      "end_ms": 106180
    },
    {
      "_id": "69199f69b41f5ecfe3202efa",
      "text": "Yeah, I almost walked out like 5 times.",
      "translations": {
        "vi": "Vâng, tôi suýt bỏ đi khoảng 5 lần.",
        "th": "ใช่ ฉันเกือบจะเดินออกไปตั้ง 5 ครั้งแล้ว.",
        "id": "Ya, aku hampir keluar sekitar 5 kali.",
