      "id": "69199f69b41f5ecfe3202eec",
      "index": 41,
      "text": "It hasn't started yet.",
      "startMs": 91880,
      "endMs": 92680,
      "ipa": "ɪt ˌhæzənt ˈstɑːr.ɾɪd ˌjɛt.",
