        "ar": "لم يبدأ بعد."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202eee",
      "index": 42,
      "text": "So what are we thinking?",
      "startMs": 93160,
      "endMs": 94280,
      "ipa": "ˌsoʊ ˈwʌɾ ər wi ˈθɪŋkɪŋ?",
      "translations": {
