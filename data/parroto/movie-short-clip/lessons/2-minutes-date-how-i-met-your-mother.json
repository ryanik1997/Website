      "endMs": 95480,
      "ipa": "ˈhændz əv ˈbeɪt.",
      "translations": {
        "vi": "Tay mồi.",
        "th": "มือเหยื่อ.",
        "id": "Tangan umpan.",
        "ar": "أيادي الطعم."
