    {
      "id": "69199f69b41f5ecfe3202ee8",
      "index": 39,
      "text": "We'll be fine.",
      "startMs": 86840,
      "endMs": 87360,
      "ipa": "ˌwiːl bi ˈfaɪn.",
      "translations": {
