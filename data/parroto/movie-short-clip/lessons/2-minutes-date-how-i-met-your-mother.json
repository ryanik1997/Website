    },
    {
      "id": "69199f69b41f5ecfe3202efe",
      "index": 50,
      "text": "On time?",
      "startMs": 109340,
      "endMs": 109700,
      "ipa": "ɑn ˈtaɪm?",
      "translations": {
        "vi": "Đúng giờ không?",
        "th": "ตรงเวลาไหม?",
        "id": "Tepat waktu?",
        "ar": "في الوقت المحدد؟?"
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f00",
      "index": 51,
      "text": "Taxi.",
      "startMs": 109700,
      "endMs": 110060,
      "ipa": "ˈtæksi.",
      "translations": {
        "vi": "Taxi.",
        "th": "แท็กซี่.",
        "id": "Taksi.",
        "ar": "تاكسي."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f02",
      "index": 52,
      "text": "We got a little time.",
      "startMs": 110060,
      "endMs": 111860,
      "ipa": "wi ˌɡɑt ə ˌlɪɾəl ˈtaɪm.",
      "translations": {
        "vi": "Chúng ta có một chút thời gian.",
        "th": "เรามีเวลานิดหน่อย.",
        "id": "Kita punya sedikit waktu.",
        "ar": "لدينا القليل من الوقت."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f04",
      "index": 53,
      "text": "OK.",
      "startMs": 112140,
      "endMs": 112420,
      "ipa": "ˌoʊˈkeɪ.",
      "translations": {
        "vi": "OK.",
        "th": "โอเค.",
        "id": "Oke.",
        "ar": "حسناً."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f06",
      "index": 54,
      "text": "You want to walk it?",
      "startMs": 112420,
      "endMs": 113300,
      "ipa": "jə ˌwɑnə ˈwɔk ɪt?",
      "translations": {
        "vi": "Anh muốn đi bộ không?",
        "th": "คุณอยากเดินไปไหม?",
        "id": "Kau mau jalan kaki?",
        "ar": "هل تريد أن نمشي؟?"
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f08",
      "index": 55,
      "text": "Why not?",
      "startMs": 114020,
      "endMs": 114580,
      "ipa": "ˈwaɪ ˈnɑt?",
      "translations": {
        "vi": "Tại sao không?",
        "th": "ทำไมจะไม่ล่ะ?",
        "id": "Kenapa tidak?",
        "ar": "لم لا؟?"
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f0a",
      "index": 56,
      "text": "Hello.",
      "startMs": 115100,
      "endMs": 115260,
      "ipa": "həˈloʊ.",
      "translations": {
        "vi": "Xin chào.",
        "th": "สวัสดี.",
        "id": "Halo.",
        "ar": "مرحباً."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f0c",
      "index": 57,
      "text": "Goodbye.",
      "startMs": 116420,
      "endMs": 116740,
      "ipa": "ˌɡʊdˈbaɪ.",
      "translations": {
        "vi": "Tạm biệt.",
        "th": "ลาก่อน.",
        "id": "Selamat tinggal.",
        "ar": "وداعاً."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f0e",
      "index": 58,
      "text": "So what grade's your daughter?",
      "startMs": 118480,
      "endMs": 119440,
      "ipa": "soʊ wʌt ˈɡreɪdz jər ˈdɔɾər?",
      "translations": {
        "vi": "Vậy con gái anh học lớp mấy?",
        "th": "แล้วลูกสาวคุณอยู่ชั้นอะไร?",
        "id": "Jadi putri Anda kelas berapa?",
        "ar": "إذاً في أي صف ابنتك؟?"
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f10",
      "index": 59,
      "text": "In 3rd grade.",
      "startMs": 119440,
      "endMs": 120480,
      "ipa": "ɪn ˌθɝd ˈɡreɪd.",
      "translations": {
        "vi": "Lớp 3.",
        "th": "อยู่ชั้นประถมปีที่ 3.",
        "id": "Kelas 3.",
        "ar": "في الصف الثالث."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f12",
      "index": 60,
      "text": "It's a good year.",
      "startMs": 121000,
      "endMs": 121520,
      "ipa": "ɪts ə ˌɡʊd ˈjɪr.",
      "translations": {
        "vi": "Đó là một năm tốt.",
        "th": "เป็นปีที่ดี.",
        "id": "Ini tahun yang baik.",
        "ar": "إنها سنة جيدة."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f14",
      "index": 61,
      "text": "Yeah, she's wonderful.",
      "startMs": 121840,
      "endMs": 122920,
      "ipa": "jɛə, ʃiːz ˈwʌndɚfəl.",
      "translations": {
        "vi": "Vâng, con bé tuyệt vời.",
        "th": "ใช่ เธอวิเศษมาก.",
        "id": "Ya, dia luar biasa.",
        "ar": "أجل، إنها رائعة."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f16",
      "index": 62,
      "text": "I just wish that I could get her to quit smoking.",
      "startMs": 123200,
      "endMs": 125160,
      "ipa": "ˈaɪ ˈdʒʌst ˈwɪʃ ðət ˈaɪ kəd ˈɡɛt ər tə ˈkwɪt ˈsmoʊkɪŋ.",
      "translations": {
        "vi": "Tôi chỉ ước tôi có thể khiến con bé bỏ thuốc lá.",
        "th": "ฉันแค่หวังว่าฉันจะทำให้เธอเลิกบุหรี่ได้.",
        "id": "Aku hanya berharap aku bisa membuatnya berhenti merokok.",
        "ar": "أتمنى لو أستطيع أن أجعلها تتوقف عن التدخين."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f18",
      "index": 63,
      "text": "You know what?",
      "startMs": 125160,
      "endMs": 125920,
      "ipa": "jə ˌnoʊ ˈwʌt?",
      "translations": {
        "vi": "Anh biết không?",
        "th": "คุณรู้ไหม?",
        "id": "Kau tahu apa?",
        "ar": "أتعلم ماذا؟?"
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f1a",
      "index": 64,
      "text": "I'm kidding.",
      "startMs": 126440,
      "endMs": 126840,
      "ipa": "aɪm ˈkɪdɪŋ.",
      "translations": {
        "vi": "Tôi đùa đấy.",
        "th": "ฉันล้อเล่น.",
        "id": "Aku bercanda.",
        "ar": "أنا أمزح."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f1c",
      "index": 65,
      "text": "Oh, little coffee and dessert.",
      "startMs": 126840,
      "endMs": 129000,
      "ipa": "oʊ, ˈlɪɾəl ˈkɑfi ən dɪˈzɜrt.",
      "translations": {
        "vi": "Ồ, một chút cà phê và món tráng miệng.",
        "th": "โอ้ กาแฟกับของหวานนิดหน่อย.",
        "id": "Oh, sedikit kopi dan hidangan penutup.",
        "ar": "أوه، قهوة صغيرة وحلوى."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f20",
      "index": 66,
      "text": "You know, this neighborhood just keeps on changing.",
      "startMs": 130520,
      "endMs": 132320,
      "ipa": "ju ˈnoʊ, ðɪs ˈneɪbərˌhʊd dʒʌst ˈkiːps ɑn ˈtʃeɪndʒɪŋ.",
      "translations": {
        "vi": "Anh biết không, khu phố này cứ thay đổi mãi.",
        "th": "คุณรู้ไหม ย่านนี้มันเปลี่ยนไปเรื่อยๆ เลย.",
        "id": "Kau tahu, lingkungan ini terus berubah.",
        "ar": "تعلم، هذا الحي يستمر في التغير."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f23",
      "index": 67,
      "text": "This used to be a cute little Italian restaurant.",
      "startMs": 132320,
      "endMs": 133920,
      "ipa": "ðɪs juːstə bi ə ˌkjuːt ˌlɪɾəl ɪˈtæljən ˈrɛstərɑːnt.",
      "translations": {
        "vi": "Đây từng là một nhà hàng Ý nhỏ xinh.",
        "th": "ที่นี่เคยเป็นร้านอาหารอิตาเลียนเล็กๆ น่ารัก.",
        "id": "Ini dulunya restoran Italia kecil yang lucu.",
        "ar": "كان هذا مطعماً إيطالياً صغيراً ولطيفاً."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f29",
      "index": 68,
      "text": "I know.",
      "startMs": 134040,
      "endMs": 134360,
      "ipa": "ˈaɪ ˈnoʊ.",
      "translations": {
        "vi": "Tôi biết.",
        "th": "ฉันรู้.",
        "id": "Aku tahu.",
        "ar": "أعرف."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f2d",
      "index": 69,
      "text": "New York.",
      "startMs": 134440,
      "endMs": 134960,
      "ipa": "ˌnuː ˈjɔːrk.",
      "translations": {
        "vi": "New York.",
        "th": "นิวยอร์ก.",
        "id": "New York.",
        "ar": "نيويورك."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f31",
      "index": 70,
      "text": "It's a living Organism.",
      "startMs": 135280,
      "endMs": 136200,
      "ipa": "ɪts ə ˈlɪvɪŋ ˈɔrɡəˌnɪzəm.",
      "translations": {
        "vi": "Nó là một Sinh vật sống.",
        "th": "มันคือสิ่งมีชีวิต.",
        "id": "Itu Organisme hidup.",
        "ar": "إنه كائن حي."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f36",
      "index": 71,
      "text": "An ever changing tapestry.",
      "startMs": 136200,
      "endMs": 137440,
      "ipa": "ən ˈɛvər ˈtʃeɪndʒɪŋ ˈtæpɪstri.",
      "translations": {
        "vi": "Một tấm thảm không ngừng thay đổi.",
        "th": "ผืนผ้าที่เปลี่ยนแปลงอยู่เสมอ.",
        "id": "Sebuah permadani yang selalu berubah.",
        "ar": "نسيج يتغير باستمرار."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f39",
      "index": 72,
      "text": "Oh, look at the time.",
      "startMs": 137520,
      "endMs": 138640,
      "ipa": "ˈoʊ, ˈlʊk ət ðə ˈtaɪm.",
      "translations": {
        "vi": "Ồ, nhìn đồng hồ kìa.",
        "th": "โอ้ ดูเวลาสิ.",
        "id": "Oh, lihat jam.",
        "ar": "أوه، انظر إلى الوقت."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f3b",
      "index": 73,
      "text": "Let's go.",
      "startMs": 139240,
      "endMs": 139560,
      "ipa": "ˈlɛts ˈɡoʊ.",
      "translations": {
        "vi": "Đi thôi.",
        "th": "ไปกันเถอะ.",
        "id": "Ayo pergi.",
        "ar": "هيا بنا."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f3d",
      "index": 74,
      "text": "So she's amazing.",
      "startMs": 140680,
      "endMs": 141520,
      "ipa": "soʊ ʃiːz əˈmeɪzɪŋ.",
      "translations": {
        "vi": "Vậy là cô ấy thật tuyệt vời.",
        "th": "งั้นเธอก็สุดยอดเลย.",
        "id": "Jadi dia luar biasa.",
        "ar": "إذاً هي مذهلة."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f3f",
      "index": 75,
      "text": "Flowers.",
      "startMs": 143240,
      "endMs": 143680,
      "ipa": "ˈflaʊ.ɚz.",
      "translations": {
        "vi": "Hoa.",
        "th": "ดอกไม้.",
        "id": "Bunga.",
        "ar": "زهور."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f41",
      "index": 76,
      "text": "I'm allergic.",
      "startMs": 144240,
      "endMs": 144720,
      "ipa": "aɪm əˈlɜːrdʒɪk.",
      "translations": {
        "vi": "Tôi bị dị ứng.",
        "th": "ฉันแพ้.",
        "id": "Aku alergi.",
        "ar": "أنا لدي حساسية."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f43",
      "index": 77,
      "text": "OK, see, we're getting to know each other.",
      "startMs": 145520,
      "endMs": 147920,
      "ipa": "ˌoʊˈkeɪ, ˈsiː, wɪər ˈɡɛɾɪŋ tə ˈnoʊ ˌiːtʃ ˈʌðər.",
      "translations": {
        "vi": "OK, thấy chưa, chúng ta đang tìm hiểu nhau đấy.",
        "th": "โอเค เห็นไหม เรากำลังทำความรู้จักกัน.",
        "id": "Oke, lihat, kita mulai saling mengenal.",
        "ar": "حسناً، انظر، نحن نتعرف على بعضنا البعض."
      }
    },
    {
      "id": "69199f69b41f5ecfe3202f48",
      "index": 78,
      "text": "Stella, I had a lovely doggy back.",
      "startMs": 148600,
      "endMs": 151720,
      "ipa": "ˈstɛlə, ˈaɪ ˈhæd ə ˈlʌvli ˈdɔɡi ˈbæk.",
      "translations": {
