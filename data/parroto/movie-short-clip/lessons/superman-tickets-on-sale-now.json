    },
    {
      "id": "6867fb313e9f070e832556aa",
      "index": 8,
      "text": "Good luck with that.",
      "startMs": 70563,
      "endMs": 71849,
      "ipa": "ɡʊd lʌk wɪð ðæt",
      "translations": {
        "vi": "Chúc may mắn với điều đó",
        "th": "ขอให้โชคดีละกัน",
        "id": "Semoga berhasil.",
        "ar": "حظًا سعيدًا بذلك."
      }
    },
    {
      "id": "6867fb313e9f070e832556ac",
      "index": 9,
      "text": "Make a move, Big Blue.",
      "startMs": 71899,
      "endMs": 81754,
      "ipa": "meɪk ə muːv, bɪɡ bluː",
      "translations": {
