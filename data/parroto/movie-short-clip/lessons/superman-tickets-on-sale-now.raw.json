  "sentence_ids": [
    {
      "_id": "6867fb313e9f070e83255699",
      "text": "Superman.",
      "translations": {
        "vi": "Siêu nhân",
        "th": "ซูเปอร์แมน",
        "id": "Superman.",
        "ar": "سوبرمان."
      },
      "ipa": "ˈsuːpəmæn",
      "start_ms": 0,
      "end_ms": 6124
    },
    {
      "_id": "6867fb313e9f070e8325569c",
      "text": "The most powerful being on planet Earth.",
      "translations": {
        "vi": "Sinh vật mạnh nhất hành tinh Trái đất",
        "th": "สิ่งมีชีวิตที่ทรงพลังที่สุดในโลก",
        "id": "Makhluk terkuat di planet Bumi.",
        "ar": "الكائن الأقوى على كوكب الأرض."
      },
      "ipa": "ðə məʊst ˈpaʊəfᵊl ˈbiːɪŋ ɒn ˈplænɪt ɜːθ",
      "start_ms": 6124,
      "end_ms": 16640
    },
    {
      "_id": "6867fb313e9f070e8325569e",
      "text": "We finally meet.",
      "translations": {
        "vi": "Cuối cùng chúng ta cũng gặp nhau",
        "th": "ในที่สุดเราก็ได้พบกัน",
        "id": "Akhirnya kita bertemu.",
        "ar": "أخيرًا التقينا."
      },
      "ipa": "wiː ˈfaɪnəli miːt",
      "start_ms": 16690,
      "end_ms": 21925
    },
    {
      "_id": "6867fb313e9f070e832556a0",
      "text": "Now, as planned, I'll destroy you and, of course, that reporter you always do interviews with.",
      "translations": {
        "vi": "Bây giờ, theo kế hoạch, tôi sẽ tiêu diệt bạn và tất nhiên, phóng viên mà bạn luôn phỏng vấn",
        "th": "ตอนนี้ ตามแผน ฉันจะกำจัดนายและแน่นอน รวมถึงนักข่าวที่นายให้สัมภาษณ์ด้วย",
        "id": "Sekarang, sesuai rencana, aku akan menghancurkanmu dan, tentu saja, reporter yang selalu kau wawancarai itu.",
        "ar": "الآن، كما هو مُخطط، سأُدمركَ، وبالطبع ذلكَ الصحفي الذي تُجري معه دائمًا المُقابلات."
      },
      "ipa": "naʊ, æz plænd, aɪl dɪˈstrɔɪ juː ænd, ɒv kɔːs, ðæt rɪˈpɔːtə juː ˈɔːlweɪz duː ˈɪntəvjuːz wɪð",
      "start_ms": 21975,
      "end_ms": 36710
    },
    {
      "_id": "6867fb313e9f070e832556a2",
      "text": "Who raised you as a child?",
      "translations": {
        "vi": "Ai nuôi nấng con khi còn nhỏ",
        "th": "ใครเลี้ยงดูนายมาตั้งแต่เด็ก?",
        "id": "Siapa yang membesarkanmu saat kecil?",
        "ar": "مَن رَبَّاكَ وأنتَ طفل؟"
      },
      "ipa": "huː reɪzd juː æz ə ʧaɪld",
      "start_ms": 36760,
      "end_ms": 40004
    },
    {
      "_id": "6867fb313e9f070e832556a4",
      "text": "I'll kill them too.",
      "translations": {
        "vi": "Tôi cũng sẽ giết chúng",
        "th": "ฉันจะฆ่าพวกมันด้วย",
        "id": "Aku juga akan membunuh mereka.",
        "ar": "سأقتلهم أيضًا."
      },
      "ipa": "aɪl kɪl ðɛm tuː",
      "start_ms": 40054,
      "end_ms": 42334
    },
    {
      "_id": "6867fb313e9f070e832556a6",
      "text": "No matter what you do to me, Luthor, your plans won't work.",
      "translations": {
        "vi": "Dù anh có làm gì với tôi, Luthor, kế hoạch của anh cũng không thành công",
        "th": "ไม่ว่านายจะทำอะไรกับฉัน ลูเธอร์ แผนของนายก็ไม่มีทางสำเร็จ",
        "id": "Apa pun yang kau lakukan padaku, Luthor, rencanamu tak akan berhasil.",
        "ar": "مهما فعلتَ بي يا لوثر، لن تنجح خططك."
      },
      "ipa": "nəʊ ˈmætə wɒt juː duː tuː miː, Luthor, jɔː plænz wəʊnt wɜːk",
      "start_ms": 42384,
      "end_ms": 66911
    },
    {
      "_id": "6867fb313e9f070e832556a8",
      "text": "Wrap it up.",
      "translations": {
        "vi": "Quấn nó lại",
        "th": "ม้วนมันซะ",
        "id": "Bungkuslah.",
        "ar": "لفّه."
      },
      "ipa": "ræp ɪt ʌp",
      "start_ms": 66961,
      "end_ms": 70513
    },
    {
      "_id": "6867fb313e9f070e832556aa",
      "text": "Good luck with that.",
      "translations": {
        "vi": "Chúc may mắn với điều đó",
        "th": "ขอให้โชคดีละกัน",
        "id": "Semoga berhasil.",
        "ar": "حظًا سعيدًا بذلك."
      },
      "ipa": "ɡʊd lʌk wɪð ðæt",
      "start_ms": 70563,
      "end_ms": 71849
    },
    {
      "_id": "6867fb313e9f070e832556ac",
      "text": "Make a move, Big Blue.",
      "translations": {
        "vi": "Hãy hành động đi, Big Blue",
        "th": "ลงมือเลย บิ๊กบลู",
        "id": "Bergeraklah, Big Blue.",
        "ar": "تحرك، أيها الأزرق الكبير."
      },
      "ipa": "meɪk ə muːv, bɪɡ bluː",
      "start_ms": 71899,
      "end_ms": 81754
    },
    {
      "_id": "6867fb313e9f070e832556ae",
      "text": "Lock the lights.",
      "translations": {
        "vi": "Khóa đèn",
        "th": "ล็อกไฟ",
        "id": "Kunci lampunya.",
        "ar": "ثَبِّتْ الأضواءَ."
      },
      "ipa": "lɒk ðə laɪts",
      "start_ms": 81804,
      "end_ms": 90405
    },
    {
      "_id": "6867fb313e9f070e832556b0",
      "text": "Superman!  They chose him.",
      "translations": {
        "vi": "Siêu nhân,  Họ đã chọn anh ấy",
        "th": "ซูเปอร์แมน! พวกเขาเลือกเขา",
        "id": "Superman! Mereka memilihnya.",
        "ar": "سوبرمان! لقد اختاروه."
      },
      "ipa": "ˈsuːpəmæn, ðeɪ ʧəʊz hɪm",
      "start_ms": 90455,
      "end_ms": 98965
    },
    {
      "_id": "6867fb313e9f070e832556b2",
      "text": "Let them die.",
      "translations": {
        "vi": "Để họ chết",
        "th": "ปล่อยให้พวกเขาตาย",
        "id": "Biarkan mereka mati.",
        "ar": "دَعْهُم يَمُوتون."
      },
      "ipa": "lɛt ðɛm daɪ",
      "start_ms": 99015,
      "end_ms": 100151
    },
    {
      "_id": "6867fb313e9f070e832556b4",
      "text": "Hey!",
      "translations": {
        "vi": "Này",
        "th": "เฮ้!",
        "id": "Hei!",
        "ar": "أَهْلاً!"
      },
      "ipa": "heɪ",
      "start_ms": 100201,
      "end_ms": 106335
    },
    {
      "_id": "6867fb313e9f070e832556b6",
      "text": "Quit messing around.",
      "translations": {
        "vi": "Đừng quậy nữa",
        "th": "เลิกเล่นซนได้แล้ว",
        "id": "Jangan main-main.",
        "ar": "تَوَقَّفْ عن العبث."
      },
      "ipa": "kwɪt ˈmɛsɪŋ əˈraʊnd",
      "start_ms": 106385,
      "end_ms": 107591
    },
    {
      "_id": "6867fb313e9f070e832556b8",
      "text": "I'm not messing around.",
      "translations": {
        "vi": "Tôi không quậy đâu",
        "th": "ฉันไม่ได้เล่นซน",
        "id": "Aku tidak main-main.",
        "ar": "أنا لا أعبث."
      },
      "ipa": "aɪm nɒt ˈmɛsɪŋ əˈraʊnd",
      "start_ms": 107641,
      "end_ms": 108555
    },
    {
      "_id": "6867fb313e9f070e832556ba",
      "text": "I'm doing important stuff.",
      "translations": {
        "vi": "Tôi đang làm những việc quan trọng",
        "th": "ฉันกำลังทำสิ่งสำคัญอยู่",
        "id": "Aku sedang melakukan hal-hal penting.",
        "ar": "أنا أفعل أشياء مُهِمَّة."
      },
      "ipa": "aɪm ˈduːɪŋ ɪmˈpɔːtᵊnt stʌf",
      "start_ms": 108605,
      "end_ms": 109632
    },
    {
      "_id": "6867fb313e9f070e832556bc",
      "text": "Hey, buddy.",
      "translations": {
        "vi": "Này, anh bạn",
        "th": "นี่ พี่ชาย",
        "id": "Hei, sobat.",
        "ar": "أَهْلاً يا صاحبي."
      },
      "ipa": "heɪ, ˈbʌdi",
