# Copy to .env.local for local dev:
#   cp .env.example .env.local
#
# On Vercel: Project Settings → Environment Variables → add both keys below.
# Values from Supabase Dashboard → Project Settings → API.
#
# Required at build time (Vite inlines VITE_* into the bundle).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Local Kokoro TTS gateway (pnpm dev:server). Optional — defaults to http://localhost:8787
VITE_TTS_SERVICE_URL=http://localhost:8787