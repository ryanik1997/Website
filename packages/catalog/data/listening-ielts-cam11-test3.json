      "passageTitle": "ETHNOGRAPHY IN BUSINESS",
      "notePassage": [
        {
          "type": "static",
          "text": "Ethnography: research which explores human cultures"
        },
        {
          "type": "static",
          "text": "It can be used in business:"
        },
        {
          "type": "static",
          "text": "• to investigate customer needs and"
        },
        {
          "type": "gap",
          "number": 31
        },
        {
          "type": "static",
          "text": "• to help companies develop new designs"
        },
        {
          "type": "section",
          "text": "Examples of ethnographic research in business"
        },
        {
          "type": "section",
          "text": "Kitchen equipment"
        },
        {
          "type": "static",
          "text": "• Researchers found that cooks could not easily see the"
        },
        {
          "type": "gap",
          "number": 32
